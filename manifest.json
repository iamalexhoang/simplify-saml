{
  "manifest_version": 3,
  "name": "Simplify SAML",
  "version": "1.0.0",
  "description": "Summarizes SAML metadata (entityID, ACS, SSO, SLO, NameID formats, and certificates) in a human-readable view.",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Simplify SAML"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}